      "name": "NewsAPI - AI",
      "type": "newsapi",
      "enabled": true,
      "pollIntervalMinutes": 30,
      "config": {
        "query": "artificial intelligence OR machine learning OR LLM OR GPT OR generative AI",
        "language": "en",
        "sortBy": "publishedAt"
      }
