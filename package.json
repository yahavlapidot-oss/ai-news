{
  "name": "ai-insight-hub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "src/backend",
    "src/mobile"
  ],
  "scripts": {
    "build": "npm run build --workspace=src/backend",
    "test": "npm run test --workspace=src/backend && npm run test --workspace=src/mobile",
    "lint": "npm run lint --workspace=src/backend && npm run lint --workspace=src/mobile",
    "dev:backend": "npm run dev --workspace=src/backend",
    "dev:mobile": "npm run start --workspace=src/mobile",
    "seed": "npm run seed --workspace=src/backend"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
